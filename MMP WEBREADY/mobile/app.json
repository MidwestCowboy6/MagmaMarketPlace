{
  "expo": {
    "name": "Magma Marketplace",
    "slug": "magma-marketplace",
    "scheme": "magmamarket",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.magmamarketplace.app"
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "package": "com.magmamarketplace.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
