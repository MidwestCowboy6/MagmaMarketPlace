{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./src/*"],
      "@better-auth/expo/client": ["./node_modules/@better-auth/expo/dist/client"],
      "@better-auth/expo/plugins": ["./node_modules/@better-auth/expo/dist/plugins/index"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", "nativewind-env.d.ts", ".expo/types/**/*.ts", "expo-env.d.ts"],
  "exclude": ["node_modules", "backend/node_modules", "backend/generated", ".expo"]
}
